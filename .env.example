# Meeting Transcriber Configuration

# Whisper model: large-v3-turbo recommended (fastest + most accurate on GTX 1080)
WHISPER_MODEL=large-v3-turbo

# Device: cuda or cpu
WHISPER_DEVICE=cuda

# Compute type: float16 (Ampere+), int8_float32 (older GPUs like GTX 1080), int8 (CPU)
WHISPER_COMPUTE_TYPE=int8_float32

# VAD-based chunking parameters
AUDIO_MIN_CHUNK_SECONDS=1.5
AUDIO_MAX_CHUNK_SECONDS=15
AUDIO_SILENCE_THRESHOLD=0.005
AUDIO_SILENCE_DURATION_MS=300
AUDIO_OVERLAP_SECONDS=1.0

# Web server port
WEB_PORT=8765

# Session storage directory
SESSIONS_DIR=./sessions

# HuggingFace token (required for pyannote speaker diarization)
# 1. Get a token at https://huggingface.co/settings/tokens
# 2. Accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# 3. Accept terms at https://huggingface.co/pyannote/embedding
HF_TOKEN=
